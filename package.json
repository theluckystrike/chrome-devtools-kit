    "author": "Zovo <hello@zovo.one>",
    "license": "MIT",
    "keywords": [
        "chrome-devtools",
        "devtools-extension",
        "devtools-panel",
        "chrome-extension",
        "devtools-sidebar",
        "chrome-devtools-api",
        "manifest-v3",
        "browser-extension",
        "devtools",
        "inspector"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/theluckystrike/chrome-devtools-kit.git"
    },
    "homepage": "https://github.com/theluckystrike/chrome-devtools-kit",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
